{
  "name": "@ai-dev-methodologies/rlp-desk",
  "version": "0.14.0",
  "description": "Fresh-context iterative loops for Claude Code — autonomous task completion with independent verification",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "uninstall": "node scripts/uninstall.js",
    "test:node": "node --test 'tests/node/*.mjs' 'tests/node/*.test.mjs'",
    "test:zsh": "for f in tests/test_*.sh; do echo \"=== $f ===\"; zsh \"$f\" || exit 1; done",
    "test:fast": "npm run test:node",
    "test:full": "npm run test:fast && npm run test:zsh",
    "sv-gate:fast": "zsh tests/sv-gate-fast.sh",
    "sv-gate:full": "zsh tests/sv-gate-full.sh"
  },
  "files": [
    "src/commands/",
    "src/node/",
    "src/governance.md",
    "src/model-upgrade-table.md",
    "scripts/",
    "docs/",
    "examples/",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "ralph-loop",
    "ai-coding",
    "fresh-context",
    "agent-loop",
    "autonomous",
    "verification"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-dev-methodologies/rlp-desk.git"
  },
  "homepage": "https://github.com/ai-dev-methodologies/rlp-desk",
  "bugs": {
    "url": "https://github.com/ai-dev-methodologies/rlp-desk/issues"
  },
  "license": "MIT",
  "author": "ai-dev-methodologies",
  "engines": {
    "node": ">=16"
  }
}
